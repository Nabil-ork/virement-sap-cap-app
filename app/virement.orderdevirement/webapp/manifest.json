{
  "_version": "1.60.0",
  "sap.app": {
    "id": "virement.orderdevirement",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.22.0",
      "toolsId": "37371766-4c84-42fb-bddd-dcf46945185a"
    },
    "dataSources": {
      "mainService": {
        "uri": "/service/virement/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "virementorderdevirement-display": {
          "semanticObject": "virementorderdevirement",
          "action": "display",
          "title": "{{virementorderdevirement-display.flpTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.120.13",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "virement.orderdevirement.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "JournalEntryPrintList",
          "target": "JournalEntryPrintList"
        },
        {
          "pattern": "JournalEntryPrint({key}):?query:",
          "name": "JournalEntryPrintObjectPage",
          "target": "JournalEntryPrintObjectPage"
        }
      ],
      "targets": {
        "JournalEntryPrintList": {
          "type": "Component",
          "id": "JournalEntryPrintList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/JournalEntryPrint",
              "variantManagement": "Page",
              "navigation": {
                "JournalEntryPrint": {
                  "detail": {
                    "route": "JournalEntryPrintObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "actions": {
                    "DataFieldForAction::virementSrv.print": {
                      "press": "virement.orderdevirement.ext.actions.Print.onPrint",
                      "requiresSelection": true,
                      "visible": false
                    },
                    "CustomPrintPDF": {
                      "press": "virement.orderdevirement.ext.actions.Print.onPrint",
                      "text": "Print",
                      "requiresSelection": true,
                      "visible": true
                    }
                  },
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "JournalEntryPrintObjectPage": {
          "type": "Component",
          "id": "JournalEntryPrintObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/JournalEntryPrint",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.Identification": {
                  "actions": {
                    "DataFieldForAction::virementSrv.print": {
                      "press": "virement.orderdevirement.ext.actions.Print.onPrint"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
